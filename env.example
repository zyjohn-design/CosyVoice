# ============================================================
# CosyVoice TTS Docker 环境变量
# cp .env.example .env && vim .env
# ============================================================

API_PORT=8080

# 模型 (容器内路径)
MODEL_DIR=pretrained_models/CosyVoice2-0.5B

# 宿主机模型目录
MODEL_HOST_DIR=./pretrained_models

# wetext 缓存 (macOS)
WETEXT_CACHE_DIR=/Users/zhangyong/.cache/modelscope/hub/pengzhendong/wetext
# wetext 缓存 (Linux)
# WETEXT_CACHE_DIR=/root/.cache/modelscope/hub/pengzhendong/wetext

# GPU 设备 ID (nvidia-smi 看到的编号)
# "0" = 第1张, "1" = 第2张
GPU_DEVICE_ID=0

# GPU 优化
LOAD_JIT=true
LOAD_TRT=false
FP16=true

# vLLM 加速 LLM decoding (约 4x 提速)
# 需要先在容器内安装: pip install vllm==v0.9.0 transformers==4.51.3 numpy==1.26.4
# 或在 Dockerfile 中取消注释 vllm 安装行
LOAD_VLLM=false

# 并发: L20→4~6, A800→8~12
MAX_CONCURRENCY=4
