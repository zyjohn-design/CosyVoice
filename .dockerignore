static/wavs/
uploads/
logs/
*.wav
*.mp3

# Git
.git/
.gitmodules
.github/

# macOS
.DS_Store
._*

# IDE
.idea/
.vscode/
*.swp
*.swo

# Docker
*.tar.gz
*.tar
*.md
